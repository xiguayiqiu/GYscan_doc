<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_blue"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/theme_blue"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <ImageView
                        android:id="@+id/appLogo"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/app"
                        android:contentDescription="应用图标"
                        android:layout_gravity="center"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:id="@+id/appName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="弈安录"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_blue"
                        android:layout_gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/appVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_version_text"
                        android:textSize="16sp"
                        android:textColor="@color/hint_text"
                        android:layout_gravity="center"
                        android:layout_marginBottom="24dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/hint_text"
                        android:alpha="0.2"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:id="@+id/softwareTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="软件"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_blue"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="应用版本:" 
                                android:textSize="16sp"
                                android:textColor="@color/hint_text" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/app_version"
                                android:textSize="16sp"
                                android:textColor="@color/black" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="Android版本:" 
                                android:textSize="16sp"
                                android:textColor="@color/hint_text" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10.0+"
                                android:textSize="16sp"
                                android:textColor="@color/black" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="系统要求:" 
                                android:textSize="16sp"
                                android:textColor="@color/hint_text" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="检测中..."
                                android:textSize="16sp"
                                android:textColor="@color/black" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="开发工具:" 
                                android:textSize="16sp"
                                android:textColor="@color/hint_text" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Android Studio"
                                android:textSize="16sp"
                                android:textColor="@color/black" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="作者:" 
                                android:textSize="16sp"
                                android:textColor="@color/hint_text" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="弈秋忘忧白帽"
                                android:textSize="16sp"
                                android:textColor="@color/black" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="开源协议:" 
                                android:textSize="16sp"
                                android:textColor="@color/hint_text" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Apache 2.0"
                                android:textSize="16sp"
                                android:textColor="@color/black" />
                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/hint_text"
                        android:alpha="0.2"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:id="@+id/hardwareTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="系统"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_blue"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:id="@+id/systemInfoLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="设备制造商:" 
                                android:textSize="16sp"
                                android:textColor="@color/hint_text" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="未知"
                                android:textSize="16sp"
                                android:textColor="@color/black" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="设备型号:" 
                                android:textSize="16sp"
                                android:textColor="@color/hint_text" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="未知"
                                android:textSize="16sp"
                                android:textColor="@color/black" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="屏幕分辨率:" 
                                android:textSize="16sp"
                                android:textColor="@color/hint_text" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="未知"
                                android:textSize="16sp"
                                android:textColor="@color/black" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="Root状态:" 
                                android:textSize="16sp"
                                android:textColor="@color/hint_text" />
                            <TextView
                                android:id="@+id/rootStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="检测中..."
                                android:textSize="16sp"
                                android:textColor="@color/black" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="内核版本:" 
                                android:textSize="16sp"
                                android:textColor="@color/hint_text" />
                            <TextView
                                android:id="@+id/kernelVersion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="检测中..."
                                android:textSize="16sp"
                                android:textColor="@color/black" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="ABI类型:" 
                                android:textSize="16sp"
                                android:textColor="@color/hint_text" />
                            <TextView
                                android:id="@+id/abiType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="检测中..."
                                android:textSize="16sp"
                                android:textColor="@color/black" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="SELinux状态:" 
                                android:textSize="16sp"
                                android:textColor="@color/hint_text" />
                            <TextView
                                android:id="@+id/selinuxStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="检测中..."
                                android:textSize="16sp"
                                android:textColor="@color/black" />
                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/hint_text"
                        android:alpha="0.2"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/privacyStatement"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="本软件没有获取任何权限和个人隐私，也没有广告弹窗请放心使用～"
                        android:textSize="14sp"
                        android:textColor="@color/green"
                        android:lineSpacingExtra="6dp"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/aboutTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="关于"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_blue"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/aboutDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="弈安录是一款网络安全学习平台，提供网络安全基础知识、Linux和Windows命令手册等内容，帮助用户学习和掌握网络安全技能。"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:lineSpacingExtra="8dp"
                        android:layout_marginBottom="24dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/hint_text"
                        android:alpha="0.2"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:id="@+id/linksTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="主项目链接"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/theme_blue"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GitHub"
                            android:textSize="16sp"
                            android:textColor="@color/theme_blue"
                            android:layout_marginBottom="12dp"
                            android:clickable="true"
                            android:focusable="true">
                        </TextView>

                        <TextView
                            android:id="@+id/githubLink"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="https://github.com/xiguayiqiu/GYscan"
                            android:textSize="16sp"
                            android:textColor="@color/theme_blue"
                            android:layout_marginBottom="12dp"
                            android:clickable="true"
                            android:focusable="true" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gitee"
                            android:textSize="16sp"
                            android:textColor="@color/theme_blue"
                            android:layout_marginBottom="12dp"
                            android:clickable="true"
                            android:focusable="true">
                        </TextView>

                        <TextView
                            android:id="@+id/giteeLink"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="https://gitee.com/bzhanyiqiua/GYscan"
                            android:textSize="16sp"
                            android:textColor="@color/theme_blue"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>