<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/intro_background3">

    <View
        android:id="@+id/circleTopLeft3"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/circle_gradient"
        android:alpha="0.15"
        android:layout_marginTop="-100dp"
        android:layout_marginStart="-100dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/circleBottomRight3"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/circle_gradient"
        android:alpha="0.15"
        android:layout_marginBottom="-125dp"
        android:layout_marginEnd="-125dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/circleCenter3"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:background="@drawable/circle_gradient"
        android:alpha="0.08"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="-50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/decorativeLine1_3"
        android:layout_width="2dp"
        android:layout_height="100dp"
        android:background="@drawable/line_gradient"
        android:alpha="0.3"
        android:layout_marginTop="50dp"
        android:layout_marginStart="30dp"
        android:rotation="45"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/decorativeLine2_3"
        android:layout_width="2dp"
        android:layout_height="80dp"
        android:background="@drawable/line_gradient"
        android:alpha="0.2"
        android:layout_marginBottom="50dp"
        android:layout_marginEnd="40dp"
        android:rotation="-30"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/introIcon3"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:alpha="0"
        android:elevation="8dp"
        app:layout_constraintBottom_toTopOf="@+id/introTitle3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/introTitle3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="知识库"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginTop="32dp"
        android:alpha="0"
        android:elevation="4dp"
        app:layout_constraintBottom_toTopOf="@+id/introDesc3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/introIcon3" />

    <TextView
        android:id="@+id/introDesc3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="丰富的安全知识库，\n随时查阅学习资料"
        android:textSize="16sp"
        android:textColor="#E0E0E0"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:alpha="0"
        android:elevation="4dp"
        app:layout_constraintBottom_toTopOf="@+id/startButton3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/introTitle3" />

    <Button
        android:id="@+id/startButton3"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="立即开始"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="@color/btn_green"
        android:stateListAnimator="@animator/btn_scale_animator"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginBottom="80dp"
        android:elevation="12dp"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:cornerRadius="28dp" />

    <TextView
        android:id="@+id/versionText3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_version_text"
        android:textSize="12sp"
        android:textColor="#B0B0B0"
        android:layout_marginBottom="8dp"
        android:elevation="4dp"
        app:layout_constraintBottom_toTopOf="@+id/pageIndicator3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/pageIndicator3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3 / 3"
        android:textSize="14sp"
        android:textColor="#B0B0B0"
        android:layout_marginBottom="16dp"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>