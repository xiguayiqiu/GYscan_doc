{
  "name": "GitHub风格",
  "body": {
    "backgroundColor": "#ffffff",
    "color": "#24292e",
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji'",
    "lineHeight": "1.5",
    "padding": "20px",
    "fontSize": "16px"
  },
  "h1": {
    "color": "#24292e",
    "fontSize": "24px",
    "marginTop": "24px",
    "marginBottom": "16px",
    "fontWeight": "600",
    "lineHeight": "1.25"
  },
  "h2": {
    "color": "#24292e",
    "fontSize": "20px",
    "marginTop": "24px",
    "marginBottom": "16px",
    "fontWeight": "600",
    "lineHeight": "1.25"
  },
  "h3": {
    "color": "#24292e",
    "fontSize": "16px",
    "marginTop": "24px",
    "marginBottom": "16px",
    "fontWeight": "600",
    "lineHeight": "1.25"
  },
  "p": {
    "marginBottom": "16px"
  },
  "pre": {
    "backgroundColor": "#f6f8fa",
    "padding": "16px",
    "borderRadius": "6px",
    "overflowX": "auto",
    "marginBottom": "16px",
    "fontSize": "14px",
    "border": "1px solid #e1e4e8"
  },
  "code": {
    "fontFamily": "SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace",
    "fontSize": "13px",
    "color": "#24292e",
    "backgroundColor": "#f6f8fa",
    "padding": "0.2em 0.4em",
    "borderRadius": "3px"
  },
  "pre code": {
    "backgroundColor": "transparent",
    "padding": "0",
    "borderRadius": "0",
    "border": "none"
  },
  "ul": {
    "marginBottom": "16px",
    "paddingLeft": "2em"
  },
  "ol": {
    "marginBottom": "16px",
    "paddingLeft": "2em"
  },
  "li": {
    "marginBottom": "0.5em"
  },
  "hr": {
    "margin": "24px 0",
    "border": "0",
    "borderTop": "1px solid #eaecef"
  },
  "strong": {
    "fontWeight": "600"
  },
  "em": {
    "fontStyle": "italic"
  },
  "a": {
    "color": "#0366d6",
    "textDecoration": "none"
  },
  "a:hover": {
    "textDecoration": "underline"
  }
}